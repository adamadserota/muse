{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd sunobrain/sunobrain && npm install",
  "buildCommand": "cd sunobrain/sunobrain && npm run build",
  "outputDirectory": "sunobrain/sunobrain/dist",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/album-cover", "destination": "/api/album-cover" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "content-type" }
      ]
    }
  ]
}
